# --- Environment ---
FA_ENV=local
LOG_LEVEL=INFO
ENABLE_DOCS=true

# --- Django backend (auth + chat persistence) ---
# If CHAT_BACKEND_URL is empty it is derived from FA_ENV:
#   local -> http://127.0.0.1:8000
#   dev   -> https://backend-admin.dev.farmbook.ugent.be
#   prd   -> https://backend-admin.prd.farmbook.ugent.be
CHAT_BACKEND_URL=
# Optional: auth/login backend if different from CHAT_BACKEND_URL.
AUTH_BACKEND_URL=
ADMIN_API_TOKEN=
# Persist each completed turn to chat_session / chat_message via /chat/log-turn/.
# Set false if a frontend logs turns itself (avoids double-writes).
AUTO_PERSIST_TURNS=true

# --- OpenSearch (reuses the same RAG endpoint as farm_assistant) ---
OPENSEARCH_API_URL=https://your-opensearch-instance.com
OPENSEARCH_API_USR=your_username
OPENSEARCH_API_PWD=your_password
VERIFY_SSL=true
OS_RAG_API_PATH=/llm_retrieve

# --- vLLM ---
VLLM_URL=https://your-vllm-instance.com
VLLM_MODEL=qwen3-30b-a3b-awq
VLLM_API_KEY=your-api-key

# --- Generation ---
MAX_OUTPUT_TOKENS=768
TEMPERATURE=0.4
NUM_CTX=4096
TOP_K=5
MAX_CONTEXT_CHARS=24000
RETRIEVAL_CANDIDATE_K=10
RETRIEVAL_MIN_SCORE=1.0

# --- Agent loop (CRAG controller) ---
# Corrective retrieval iterations after the first search. Set 0 to reproduce
# farm_assistant's single-pass behaviour.
AGENT_MAX_CORRECTIONS=2
# Heuristic relevance (token overlap) accept threshold.
AGENT_GRADE_GOOD=0.15
AGENT_GRADE_BAD=0.05
# Ask the LLM to grade borderline retrievals (costs one extra short call).
AGENT_ENABLE_LLM_GRADER=false
AGENT_LLM_GRADE_PASS=0.5
# Verify each retrieved source against the question's specific constraints (country,
# time, crop, species, project) and drop topical-but-off-constraint sources. One LLM
# call per grounded turn; fail-open. Set false to skip.
AGENT_ENABLE_CONSTRAINT_FILTER=true
# If constraint verification drops ALL sources, try one constraint-targeted re-retrieval
# before falling back to a general answer.
AGENT_ENABLE_CONSTRAINT_RECOVERY=true
# Self-RAG: after a grounded answer, verify its claims against the cited sources and append
# an honest caveat if it overstates them. One LLM call per grounded turn.
AGENT_ENABLE_ANSWER_VERIFICATION=true
# Split multi-part questions into sub-queries (off by default to protect latency).
AGENT_ENABLE_DECOMPOSITION=false
AGENT_MAX_SUBQUERIES=3
# After exhausting corrections, drop still-weak contexts and answer from general
# knowledge instead of grounding in noise.
AGENT_DROP_WEAK_CONTEXTS=true

# --- Concurrency ---
MAX_ACTIVE_GENERATIONS=3
