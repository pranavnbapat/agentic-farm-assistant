# =========================
# Core Application
# =========================
FA_ENV=local
LOG_LEVEL=INFO
ENABLE_DOCS=true
ENABLE_REDOC=false
MAX_ACTIVE_GENERATIONS=3

# =========================
# Backend (auth + chat persistence)
# =========================
# Leave blank for local mode; resolved at runtime from FA_ENV otherwise.
CHAT_BACKEND_URL=
AUTH_BACKEND_URL=
ADMIN_API_TOKEN=
# Persist each completed turn via /chat/log-turn/.
# Set false if a frontend logs turns itself (avoids double-writes).
AUTO_PERSIST_TURNS=true

# =========================
# OpenSearch
# =========================
OPENSEARCH_API_URL=
OPENSEARCH_API_USR=
OPENSEARCH_API_PWD=
VERIFY_SSL=true
# RAG retrieval endpoint used by the agent's retrieve tool.
OS_RAG_API_PATH=/llm_retrieve

# =========================
# vLLM
# =========================
VLLM_URL=
VLLM_MODEL=qwen3-30b-a3b-awq
VLLM_API_KEY=

# =========================
# Generation Limits
# =========================
TEMPERATURE=0.4
NUM_CTX=16384
TOP_K=5
RETRIEVAL_CANDIDATE_K=10
RETRIEVAL_MIN_SCORE=1.0
MAX_CONTEXT_CHARS=24000
MAX_OUTPUT_TOKENS=4000
MAX_INPUT_TOKENS=12000
MAX_USER_INPUT_TOKENS=2000

# =========================
# Agent loop (CRAG controller)
# =========================
# Corrective retrieval iterations after the first search.
# Set 0 to reproduce farm_assistant's single-pass behaviour.
AGENT_MAX_CORRECTIONS=2
# Heuristic relevance (token overlap) accept threshold.
AGENT_GRADE_GOOD=0.15
AGENT_GRADE_BAD=0.05
# Ask the LLM to grade borderline retrievals (costs one extra short call).
AGENT_ENABLE_LLM_GRADER=false
AGENT_LLM_GRADE_PASS=0.5
# Verify each retrieved source against the question's specific constraints
# (country, time, crop, species, project) and drop topical-but-off-constraint
# sources. One LLM call per grounded turn; fail-open. Set false to skip.
AGENT_ENABLE_CONSTRAINT_FILTER=true
# If constraint verification drops ALL sources, try one constraint-targeted
# re-retrieval before falling back to a general answer.
AGENT_ENABLE_CONSTRAINT_RECOVERY=true
# Self-RAG: after a grounded answer, verify its claims against the cited
# sources and append an honest caveat if it overstates them. One LLM call
# per grounded turn.
AGENT_ENABLE_ANSWER_VERIFICATION=true
# Split multi-part questions into sub-queries (off by default to protect latency).
AGENT_ENABLE_DECOMPOSITION=false
AGENT_MAX_SUBQUERIES=3
# After exhausting corrections, drop still-weak contexts and answer from
# general knowledge instead of grounding in noise.
AGENT_DROP_WEAK_CONTEXTS=true
